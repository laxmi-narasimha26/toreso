  buyer                 Organization? @relation("BuyerShipments", fields: [buyer_id], references: [id])
  tracking_history      ShipmentTrackingHistory[]

  @@index([order_id])
  @@index([tracking_number])
  @@index([status])
  @@map("shipments")
}

model ShipmentTrackingHistory {
  id                    String    @id @default(uuid())
  shipment_id           String
  
  status                String
  location              String?
  description           String?
  timestamp             DateTime
  
  metadata              Json?
  
  created_at            DateTime  @default(now())

  shipment              Shipment  @relation(fields: [shipment_id], references: [id], onDelete: Cascade)

  @@index([shipment_id])
  @@index([timestamp(sort: Desc)])
  @@map("shipment_tracking_history")
}

// 9. Audits & Certifications

model Audit {
  id                    String    @id @default(uuid())
  audit_number          String    @unique
  
  supplier_id           String
  auditor_id            String?
  
  // Audit Details
  audit_type            String?   // 'initial', 'renewal', 'surprise', 'buyer_specific', 'follow_up'
  audit_scope           String?
  standards             String[]
  
  // Scheduling
  scheduled_date        DateTime? @db.Date
  scheduled_time        DateTime? @db.Time
  duration_hours        Int?
  
  // Status
  status                String    @default("scheduled") // 'scheduled', 'in_progress', 'completed', 'cancelled'
  
  // Results
  overall_score         Decimal?  @db.Decimal(5, 2)
  passed                Boolean?
  findings              Json?
  non_conformances      Json?
  observations          String?
  recommendations       String?
  
  // Documents
  checklist_url         String?
  report_url            String?
  photos                Json?
  evidence_documents    Json?
  
  // Dates
  conducted_date        DateTime? @db.Date
  report_submitted_date DateTime? @db.Date
  report_approved_date  DateTime? @db.Date
  
  // Follow-up
  requires_follow_up    Boolean   @default(false)
  follow_up_date        DateTime? @db.Date
  follow_up_audit_id    String?
  
  // Corrective Actions
  corrective_actions    Json?
  corrective_actions_due_date DateTime? @db.Date
  corrective_actions_completed Boolean @default(false)
  
  notes                 String?
  
  created_at            DateTime  @default(now())
  updated_at            DateTime  @default(now()) @updatedAt

  supplier              Organization @relation(fields: [supplier_id], references: [id], onDelete: Cascade)
  auditor               User?        @relation("Auditor", fields: [auditor_id], references: [id])
  follow_up_audit       Audit?       @relation("FollowUpAudit", fields: [follow_up_audit_id], references: [id])
  previous_audit_follow_up Audit[]   @relation("FollowUpAudit")

  @@index([supplier_id])
  @@index([auditor_id])
  @@index([status])
  @@index([scheduled_date])
  @@map("audits")
}

model Certification {
  id                    String    @id @default(uuid())
  organization_id       String
  
  // Certification Details
  certification_type    String    // 'ISO 9001', 'ISO 14001', 'FDA', 'BRC', 'HACCP', etc.
  certification_number  String?
  certification_name    String?
  
  // Issuing Authority
  issuing_authority     String
  accreditation_body    String?
  
  // Dates
  issue_date            DateTime  @db.Date
  expiry_date           DateTime  @db.Date
  last_renewal_date     DateTime? @db.Date
  next_renewal_date     DateTime? @db.Date
  
  // Scope
  scope                 String?
  covered_products      String[]
  covered_facilities    String[]
  
  // Document
  certificate_url       String?
  document_hash         String?
  
  // Verification
  verification_status   String    @default("pending") // 'pending', 'verified', 'rejected', 'expired'
  verified_by_id        String?
  verified_at           DateTime?
  verification_notes    String?
  
  // Status
  status                String    @default("active") // 'active', 'expired', 'suspended', 'revoked'
  
  // Notifications
  expiry_notification_sent Boolean @default(false)
  
  metadata              Json?
  
  created_at            DateTime  @default(now())
  updated_at            DateTime  @default(now()) @updatedAt

  organization          Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  verified_by           User?        @relation(fields: [verified_by_id], references: [id])

  @@index([organization_id])
  @@index([certification_type])
  @@index([expiry_date])
  @@index([status])
  @@map("certifications")
}

// 10. Communication & Messaging

model Conversation {
  id                    String    @id @default(uuid())
  
  // Participants
  participant_1_id      String?
  participant_2_id      String?
  
  // Context
  context_type          String?   // 'general', 'order', 'rfq', 'product', 'support'
  context_id            String?
  
  // Status
  status                String    @default("active") // 'active', 'archived', 'blocked'
  
  // Last Message
  last_message_at       DateTime?
  last_message_preview  String?
  
  // Unread Counts
  unread_count_p1       Int       @default(0)
  unread_count_p2       Int       @default(0)
  
  created_at            DateTime  @default(now())
  updated_at            DateTime  @default(now()) @updatedAt

  participant_1         Organization? @relation("Participant1", fields: [participant_1_id], references: [id])
  participant_2         Organization? @relation("Participant2", fields: [participant_2_id], references: [id])
  messages              Message[]

  @@unique([participant_1_id, participant_2_id, context_type, context_id])
  @@index([participant_1_id])
  @@index([participant_2_id])
  @@index([last_message_at(sort: Desc)])
  @@map("conversations")
}

model Message {
  id                    String    @id @default(uuid())
  conversation_id       String
  
  sender_id             String?
  sender_org_id         String?
  
  message_type          String    @default("text") // 'text', 'file', 'image', 'system'
  message_text          String?
  
  // Attachments
  attachments           Json?
  
  // Status
  is_read               Boolean   @default(false)
  read_at               DateTime?
  
  // Reply Reference
  reply_to_message_id   String?
  
  // System Message
  is_system_message     Boolean   @default(false)
  
  metadata              Json?
  
  created_at            DateTime  @default(now())
  updated_at            DateTime  @default(now()) @updatedAt

  conversation          Conversation @relation(fields: [conversation_id], references: [id], onDelete: Cascade)
  sender                User?        @relation(fields: [sender_id], references: [id])
  sender_org            Organization? @relation(fields: [sender_org_id], references: [id])
  reply_to_message      Message?     @relation("ReplyTo", fields: [reply_to_message_id], references: [id])
  replies               Message[]    @relation("ReplyTo")

  @@index([conversation_id])
  @@index([sender_id])
  @@index([created_at(sort: Desc)])
  @@map("messages")
}

// 11. Notifications

model Notification {
  id                    String    @id @default(uuid())
  user_id               String?
  organization_id       String?
  
  // Notification Details
  type                  String    // 'order', 'rfq', 'payment', 'message', 'system', etc.
  category              String?   // 'info', 'success', 'warning', 'error'
  title                 String
  message               String
  
  // Action
  action_url            String?
  action_text           String?
  
  // Context
  context_type          String?
  context_id            String?
  
  // Status
  is_read               Boolean   @default(false)
  read_at               DateTime?
  
  // Channels
  sent_via_email        Boolean   @default(false)
  sent_via_sms          Boolean   @default(false)
  sent_via_push         Boolean   @default(false)
  
  // Priority
  priority              String    @default("normal") // 'low', 'normal', 'high', 'urgent'
  
  metadata              Json?
  
  created_at            DateTime  @default(now())
  expires_at            DateTime?

  user                  User?         @relation(fields: [user_id], references: [id], onDelete: Cascade)
  organization          Organization? @relation(fields: [organization_id], references: [id])

  @@index([user_id])
  @@index([organization_id])
  @@index([is_read])
  @@index([created_at(sort: Desc)])
  @@map("notifications")
}

// 12. Reviews & Ratings

model SupplierReview {
  id                    String    @id @default(uuid())
  supplier_id           String
  buyer_id              String?
  user_id               String?
  order_id              String?
  
  // Overall Rating
  overall_rating        Int
  
  // Category Ratings
  product_quality_rating Int?
  delivery_time_rating  Int?
  communication_rating  Int?
  packaging_quality_rating Int?
  value_for_money_rating Int?
  
  // Review
  title                 String?
  review_text           String?
  
  // Verification
  is_verified           Boolean   @default(true)
  
  // Interaction
  helpful_count         Int       @default(0)
  not_helpful_count     Int       @default(0)
  
  // Supplier Response
  supplier_response     String?
  supplier_responded_at DateTime?
  supplier_responded_by String?
  
  // Moderation
  status                String    @default("approved") // 'pending', 'approved', 'rejected'
  moderation_notes      String?
  
  created_at            DateTime  @default(now())
  updated_at            DateTime  @default(now()) @updatedAt

  supplier              Organization @relation("SupplierReviewsReceived", fields: [supplier_id], references: [id], onDelete: Cascade)
  buyer                 Organization? @relation("SupplierReviewsGiven", fields: [buyer_id], references: [id])
  user                  User?         @relation(fields: [user_id], references: [id])

  @@index([supplier_id])
  @@index([buyer_id])
  @@index([order_id])
  @@map("supplier_reviews")
}

// 13. Analytics

model AnalyticsEvent {
  id                    String    @id @default(uuid())
  
  // Event Details
  event_name            String
  event_category        String?
  event_action          String?
  event_label           String?
  event_value           Decimal?  @db.Decimal(15, 2)
  
