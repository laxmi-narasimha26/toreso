  @@index([user_id])
  @@index([organization_id])
  @@index([created_at(sort: Desc)])
  @@map("analytics_events")
}

// 14. Documents

model Document {
  id                    String    @id @default(uuid())
  
  // Owner
  owner_type            String?   // 'organization', 'user', 'order', 'rfq', 'audit', etc.
  owner_id              String?
  
  // Document Details
  document_type         String?   // 'invoice', 'po', 'certificate', 'audit_report', 'contract', etc.
  document_name         String
  file_name             String
  file_url              String
  file_size             BigInt?
  mime_type             String?
  
  // Metadata
  description           String?
  tags                  String[]
  
  // Version Control
  version               Int       @default(1)
  parent_document_id    String?
  
  // Security
  is_public             Boolean   @default(false)
  access_permissions    Json?
  
  // Verification
  document_hash         String?
  is_verified           Boolean   @default(false)
  verified_by_id        String?
  verified_at           DateTime?
  
  // Expiry
  expires_at            DateTime?
  
  uploaded_by_id        String?
  
  created_at            DateTime  @default(now())
  updated_at            DateTime  @default(now()) @updatedAt
  deleted_at            DateTime?

  parent_document       Document? @relation("DocumentVersions", fields: [parent_document_id], references: [id])
  versions              Document[] @relation("DocumentVersions")
  uploaded_by           User?     @relation(fields: [uploaded_by_id], references: [id])

  @@index([owner_type, owner_id])
  @@index([document_type])
  @@map("documents")
}

// 15. Disputes & Support

model Dispute {
  id                    String    @id @default(uuid())
  dispute_number        String    @unique
  
  // Parties
  raised_by_type        String?   // 'buyer', 'supplier'
  raised_by_id          String?
  against_id            String?
  
  // Context
  dispute_type          String?   // 'payment', 'quality', 'delivery', 'pricing', 'other'
  order_id              String?
  invoice_id            String?
  
  // Dispute Details
  subject               String
  description           String
  evidence_documents    Json?
  expected_resolution   String?
  
  // Response
  response_text         String?
  responded_by_id       String?
  responded_at          DateTime?
  
  // Status
  status                String    @default("open") // 'open', 'investigating', 'resolved', 'closed', 'escalated'
  priority              String    @default("medium") // 'low', 'medium', 'high', 'critical'
  
  // Resolution
  resolution_type       String?   // 'refund', 'replacement', 'credit', 'rejected', 'other'
  resolution_notes      String?
  resolved_by_id        String?
  resolved_at           DateTime?
  
  // Escalation
  escalated_to_id       String?
  escalated_at          DateTime?
  escalation_reason     String?
  
  metadata              Json?
  
  created_at            DateTime  @default(now())
  updated_at            DateTime  @default(now()) @updatedAt

  raised_by             Organization? @relation("DisputesRaised", fields: [raised_by_id], references: [id])
  against               Organization? @relation("DisputesAgainst", fields: [against_id], references: [id])
  order                 Order?        @relation(fields: [order_id], references: [id])
  invoice               Invoice?      @relation(fields: [invoice_id], references: [id])
  responded_by          User?         @relation("RespondedDisputes", fields: [responded_by_id], references: [id])
  resolved_by           User?         @relation("ResolvedDisputes", fields: [resolved_by_id], references: [id])
  escalated_to          User?         @relation("EscalatedDisputes", fields: [escalated_to_id], references: [id])

  @@index([raised_by_id])
  @@index([against_id])
  @@index([order_id])
  @@index([status])
  @@map("disputes")
}

model SupportTicket {
  id                    String    @id @default(uuid())
  ticket_number         String    @unique
  
  user_id               String?
  organization_id       String?
  
  // Ticket Details
  category              String?   // 'technical', 'billing', 'account', 'order', 'general'
  subject               String
  description           String
  priority              String    @default("normal") // 'low', 'normal', 'high', 'urgent'
  
  // Assignment
  assigned_to_id        String?
  assigned_at           DateTime?
  
  // Status
  status                String    @default("open") // 'open', 'in_progress', 'waiting_customer', 'resolved', 'closed'
  
  // Resolution
  resolution            String?
  resolved_by_id        String?
  resolved_at           DateTime?
  
  // Satisfaction
  satisfaction_rating   Int?
  satisfaction_feedback String?
  
  // Attachments
  attachments           Json?
  
  metadata              Json?
  
  created_at            DateTime  @default(now())
  updated_at            DateTime  @default(now()) @updatedAt

  user                  User?     @relation(fields: [user_id], references: [id])
  organization          Organization? @relation(fields: [organization_id], references: [id])
  assigned_to           User?     @relation("AssignedSupportTickets", fields: [assigned_to_id], references: [id])
  resolved_by           User?     @relation("ResolvedSupportTickets", fields: [resolved_by_id], references: [id])

  @@index([user_id])
  @@index([organization_id])
  @@index([status])
  @@map("support_tickets")
}

// 16. System

model SystemSetting {
  id                    String    @id @default(uuid())
  setting_key           String    @unique
  setting_value         Json
  setting_type          String?   // 'string', 'number', 'boolean', 'json'
  description           String?
  is_public             Boolean   @default(false)
  updated_by_id         String?
  created_at            DateTime  @default(now())
  updated_at            DateTime  @default(now()) @updatedAt

  updated_by            User?     @relation(fields: [updated_by_id], references: [id])

  @@map("system_settings")
}

model AuditLog {
  id                    String    @id @default(uuid())
  
  // Who
  user_id               String?
  organization_id       String?
  
  // What
  entity_type           String?   // 'user', 'organization', 'order', 'product', etc.
  entity_id             String?
  action                String?   // 'create', 'update', 'delete', 'view', etc.
  
  // When
  timestamp             DateTime  @default(now())
  
  // Where
  ip_address            String?
  user_agent            String?
  
  // Changes
  changes               Json?     // {before: {}, after: {}}
  
  // Context
  metadata              Json?

  user                  User?         @relation(fields: [user_id], references: [id])
  organization          Organization? @relation(fields: [organization_id], references: [id])

  @@index([user_id])
  @@index([entity_type, entity_id])
  @@index([timestamp(sort: Desc)])
  @@map("audit_logs")
}
