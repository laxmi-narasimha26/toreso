  user_agent            String?
  device_type           String?
  browser               String?
  os                    String?
  
  // Location
  country               String?
  state                 String?
  city                  String?
  
  // Page Context
  page_url              String?
  page_title            String?
  referrer_url          String?
  
  // UTM Parameters
